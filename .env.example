# Auth
APP_USERNAME=admin
APP_PASSWORD=changeme

OLLAMA_HOST=host.docker.internal
OLLAMA_PORT=11434
QDRANT_DB_PATH=./data/qdrant
LLM_MODEL=qwen2.5:14b
EMBEDDING_MODEL=mxbai-embed-large:latest

# Vector dimension — must match the embedding model output:
#   mxbai-embed-large  → 1024  (default)
#   nomic-embed-text   →  768
#   all-minilm         →  384
EMBEDDING_VECTOR_SIZE=1024

# Chunking
CHUNK_SIZE=2000
CHUNK_OVERLAP=100

# Embedding retry: reduce chunk to FACTOR size on context-length error, up to MAX attempts
EMBEDDING_TRUNCATION_FACTOR=0.8
EMBEDDING_MAX_TRUNCATION_ATTEMPTS=12
